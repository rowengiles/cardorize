# Cardorize API configuration
# In development every value has a safe default; APP_SECRET is required in production.

PORT=8787
HOST=127.0.0.1

# Required in production. 32+ random bytes, e.g.:  openssl rand -hex 32
# Encrypts stored BYOK model API keys and derives internal keys.
APP_SECRET=

# Where the SQLite database (and dev-generated secret) live.
DATA_DIR=./data

# Set to "production" behind NGINX/TLS (enables Secure cookies).
NODE_ENV=development

# Cardorize behind NGINX — example production config.
# SPA static files + API reverse proxy. Pair with certbot for TLS.

limit_req_zone $binary_remote_addr zone=api:10m rate=20r/s;
limit_conn_zone $binary_remote_addr zone=perip:10m;

server {
    listen 80;
    server_name cardorize.ai www.cardorize.ai;
    return 301 https://cardorize.ai$request_uri;
}

server {
    listen 443 ssl http2;
    server_name cardorize.ai;

    ssl_certificate     /etc/letsencrypt/live/cardorize.ai/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cardorize.ai/privkey.pem;

    # --- Static SPA ---
    root /var/www/cardorize/web;   # contents of apps/web/dist
    index index.html;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'" always;

    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri /index.html;
    }

    # --- API ---
    location /api/ {
        limit_req zone=api burst=40 nodelay;
        limit_conn perip 20;
        client_max_body_size 50m;

        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;   # AI generation can take minutes
    }
}
